# ---------------------------------------------------------------------------
# Copy to .env.local and fill in. Every var here must ALSO be set in the Vercel
# dashboard (Project → Settings → Environment Variables) — ai_rules.md §4, Phase 0.
# ---------------------------------------------------------------------------

# --- MongoDB Atlas (M0 free tier) ------------------------------------------
# Atlas → Connect → Drivers. Remember to URL-encode any special characters in
# the password, and to allow network access from 0.0.0.0/0 for Vercel.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="timbre"

# --- Firebase: client SDK (browser) ----------------------------------------
# Firebase console → Project settings → General → Your apps → Web app → SDK config.
# These are NOT secrets — they identify the project and ship to the browser by design.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="<project-id>.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# --- Firebase: Admin SDK (server) — THESE ARE SECRETS ----------------------
# Firebase console → Project settings → Service accounts → Generate new private key.
# The downloaded JSON contains project_id, client_email and private_key.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@<project-id>.iam.gserviceaccount.com"
# Keep the surrounding quotes and the literal \n escapes exactly as they appear
# in the JSON — the app converts them back to real newlines at runtime.
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"
